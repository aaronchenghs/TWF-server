{
  "family": "twf-server",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::010928227897:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "twf-server",
      "image": "010928227897.dkr.ecr.us-east-1.amazonaws.com/twf-server:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3001,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "PORT",
          "value": "3001"
        },
        {
          "name": "CLIENT_ORIGINS",
          "value": "http://localhost:5173"
        },
        {
          "name": "ALLOW_PRIVATE_NETWORK_ORIGINS",
          "value": "false"
        },
        {
          "name": "ENABLE_DEBUG_CONTROLS",
          "value": "false"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/twf-server",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
